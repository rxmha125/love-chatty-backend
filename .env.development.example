# Backend development (local)
APP_ENV="development"
NODE_ENV="development"
PORT=3001
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB="lovechatty_dev"
CLIENT_ORIGINS="http://localhost:8080,http://localhost:5173"
TRUST_PROXY=0
LOG_LEVEL="debug"
ENABLE_CLIENT_ERROR_INGEST="true"
OPS_METRICS_ENABLED="true"
OPS_METRICS_TOKEN="dev-ops-token-change-me"
AI_PROVIDER="groq"
AI_MODEL="llama-3.3-70b-versatile"
GROQ_API_KEY=""
SEARCH_API_KEY=""
