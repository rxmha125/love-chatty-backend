# Backend production (Render/Railway/Fly/VPS)
APP_ENV="production"
NODE_ENV="production"
PORT=3001
MONGODB_URI="mongodb+srv://..."
MONGODB_DB="lovechatty"
CLIENT_ORIGINS="https://your-vercel-app.vercel.app,https://your-domain.com"
TRUST_PROXY=1
LOG_LEVEL="info"
ENABLE_CLIENT_ERROR_INGEST="true"
OPS_METRICS_ENABLED="true"
OPS_METRICS_TOKEN="replace-with-long-random-token"
AI_PROVIDER="groq"
AI_MODEL="llama-3.3-70b-versatile"
GROQ_API_KEY=""
GROQ_API_KEY_2=""
SEARCH_API_KEY=""
