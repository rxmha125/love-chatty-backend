# Backend environment (Render / local backend)
APP_ENV="development"
NODE_ENV="development"
PORT=3001
MONGODB_URI="mongodb+srv://..."
MONGODB_DB="lovechatty"

# CORS allowlist (comma-separated). Use your frontend URLs in production.
CLIENT_ORIGIN="http://localhost:8080"
CLIENT_ORIGINS="http://localhost:8080,http://localhost:5173"

# Logging / telemetry
LOG_LEVEL="info"
ENABLE_CLIENT_ERROR_INGEST="true"
OPS_METRICS_ENABLED="true"
OPS_METRICS_TOKEN="replace-with-long-random-token"

# AI runtime
AI_PROVIDER="groq"
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"
AI_KEEP_ALIVE="30m"
AI_TIMEOUT_MS=120000
AI_TEMPERATURE=0.35
GROQ_API_KEY=""
GROQ_API_KEY_2=""

# Search
SEARCH_API_KEY=""
SEARCH_TIMEOUT_MS=20000

# Security / limits (optional overrides)
TRUST_PROXY=1
API_JSON_LIMIT="2mb"
API_URLENCODED_LIMIT="512kb"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_MESSAGES_MAX=180
RATE_LIMIT_UPLOADS_MAX=40
UPLOAD_MAX_BYTES=20971520
# UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,video/mp4"
